generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  followers Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
